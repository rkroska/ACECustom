# Copy to .env.write and fill in passwords. Do not commit .env.write.
#
#   copy .env.write.example .env.write
#
# Create the MySQL user first (see create_ace_write_user.sql), then set
# MYSQL_WORLD_PASSWORD to the same password you used in that script.
#
# Host/port/database names should match Source/ACE.Server/Config.js (MySql section).

# --- World (apply quest SQL packages here) ---
MYSQL_WORLD_HOST=127.0.0.1
MYSQL_WORLD_PORT=3306
MYSQL_WORLD_DATABASE=ace_world
MYSQL_WORLD_USER=ace_write
MYSQL_WORLD_PASSWORD=

# --- Shard (optional: post-checks on character quest registry; read-only is enough) ---
MYSQL_SHARD_HOST=127.0.0.1
MYSQL_SHARD_PORT=3306
MYSQL_SHARD_DATABASE=ace_shard
MYSQL_SHARD_USER=ace_readonly
MYSQL_SHARD_PASSWORD=

# --- Auth (optional: account_quest stamp lookups; read-only is enough) ---
MYSQL_AUTH_HOST=127.0.0.1
MYSQL_AUTH_PORT=3306
MYSQL_AUTH_DATABASE=ace_auth
MYSQL_AUTH_USER=ace_readonly
MYSQL_AUTH_PASSWORD=

MYSQL_DEFAULT_DATABASE=ace_world
