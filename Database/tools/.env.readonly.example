# Copy to .env.readonly and fill in values. Do not commit .env.readonly.
#
#   copy .env.readonly.example .env.readonly
#
# MySQL user should be SELECT-only, e.g.:
#   CREATE USER 'ace_readonly'@'127.0.0.1' IDENTIFIED BY '...';
#   GRANT SELECT ON ace_world.* TO 'ace_readonly'@'127.0.0.1';
#   GRANT SELECT ON ace_shard.* TO 'ace_readonly'@'127.0.0.1';
#   GRANT SELECT ON ace_auth.* TO 'ace_readonly'@'127.0.0.1';
#   FLUSH PRIVILEGES;
#
# Host/port/database names should match Source/ACE.Server/Config.js (MySql section).

# --- World (weenies, quests, emotes, landblock_instance) ---
MYSQL_WORLD_HOST=127.0.0.1
MYSQL_WORLD_PORT=3306
MYSQL_WORLD_DATABASE=ace_world
MYSQL_WORLD_USER=ace_readonly
MYSQL_WORLD_PASSWORD=

# --- Shard (characters, biota, quest registry) ---
MYSQL_SHARD_HOST=127.0.0.1
MYSQL_SHARD_PORT=3306
MYSQL_SHARD_DATABASE=ace_shard
MYSQL_SHARD_USER=ace_readonly
MYSQL_SHARD_PASSWORD=

# --- Auth (account_quest stamps) ---
MYSQL_AUTH_HOST=127.0.0.1
MYSQL_AUTH_PORT=3306
MYSQL_AUTH_DATABASE=ace_auth
MYSQL_AUTH_USER=ace_readonly
MYSQL_AUTH_PASSWORD=

# Optional: default database when running scripts without -D
MYSQL_DEFAULT_DATABASE=ace_world
